{
  "$schema": "https://roduq.dev/schemas/v1/tokens.schema.json",
  "version": "1.0.0",
  "_meta": {
    "preset": "roduq-dark-cinematic",
    "category": "premium-saas-devtools-finance",
    "tagline": "Premium, focused, immersive. Dla high-end SaaS / developer tools / finance.",
    "description": "Jet black + neon purple + cyan. Inter Display tight tracking. Backdrop blur + subtle glows."
  },
  "tokens": {
    "color": {
      "surface": {
        "default": "#0A0A0A",
        "raised": "#141414",
        "sunken": "#000000",
        "elevated": "#1F1F1F"
      },
      "ink": {
        "primary": "#FAFAFA",
        "secondary": "#A1A1AA",
        "muted": "#71717A",
        "inverse": "#0A0A0A"
      },
      "outline": {
        "subtle": "rgba(255, 255, 255, 0.06)",
        "default": "rgba(255, 255, 255, 0.12)",
        "strong": "rgba(255, 255, 255, 0.2)"
      },
      "brand": {
        "primary": "#7C5CFC",
        "secondary": "#22D3EE"
      },
      "glow": {
        "primary": "radial-gradient(circle at center, rgba(124, 92, 252, 0.3) 0%, transparent 70%)",
        "accent": "radial-gradient(circle at center, rgba(34, 211, 238, 0.2) 0%, transparent 60%)"
      },
      "gradient": {
        "hero": "linear-gradient(135deg, #7C5CFC 0%, #22D3EE 100%)"
      },
      "status": {
        "success": "#10B981",
        "warning": "#F59E0B",
        "danger": "#EF4444"
      }
    },
    "font": {
      "display": "Inter Display, Geist, Inter Tight, -apple-system, system-ui, sans-serif",
      "body": "Inter, -apple-system, system-ui, sans-serif",
      "mono": "Geist Mono, JetBrains Mono, ui-monospace, monospace"
    },
    "spacing": {
      "3xs": "0.125rem", "2xs": "0.25rem", "xs": "0.5rem",
      "sm": "0.75rem", "md": "1rem", "lg": "1.5rem",
      "xl": "2rem", "2xl": "3rem", "3xl": "4rem", "4xl": "6rem"
    },
    "radii": {
      "sm": "0.375rem", "md": "0.625rem", "lg": "0.875rem",
      "xl": "1.125rem", "full": "9999px"
    },
    "fontSize": {
      "xs": "0.75rem", "sm": "0.875rem", "base": "1rem",
      "lg": "1.125rem", "xl": "1.25rem", "2xl": "1.5rem",
      "3xl": "1.875rem", "4xl": "2.5rem", "5xl": "3.5rem", "6xl": "4.5rem"
    },
    "shadow": {
      "sm": "0 4px 12px rgba(124, 92, 252, 0.10)",
      "md": "0 12px 24px rgba(124, 92, 252, 0.12)",
      "lg": "0 24px 48px rgba(124, 92, 252, 0.15)"
    }
  }
}
