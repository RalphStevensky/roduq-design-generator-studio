{
  "$schema": "https://roduq.dev/schemas/v1/tokens.schema.json",
  "version": "1.0.0",
  "_meta": {
    "preset": "roduq-monolith-meadow",
    "category": "heritage-hospitality-wellness",
    "tagline": "Solidność z natury. Idealne dla heritage / hospitality / wellness.",
    "description": "Warm earthy palette — sage green + terracotta + cream surfaces. Place-based storytelling voice."
  },
  "tokens": {
    "color": {
      "surface": {
        "default": "#FFFFFF",
        "raised": "#FAFAF7",
        "sunken": "#F0EFEA",
        "muted": "#E8E6DD"
      },
      "ink": {
        "primary": "#1A1C19",
        "secondary": "#525249",
        "muted": "#8A8A7F",
        "inverse": "#FAFAF7"
      },
      "outline": {
        "subtle": "rgba(26, 28, 25, 0.08)",
        "default": "rgba(26, 28, 25, 0.14)",
        "strong": "rgba(26, 28, 25, 0.24)"
      },
      "brand": {
        "primary": "#5C7A4F",
        "secondary": "#C97B5A"
      },
      "status": {
        "success": "#5C7A4F",
        "warning": "#D49C3D",
        "danger": "#B53D2C",
        "info": "#446B85"
      }
    },
    "font": {
      "display": "Recoleta, Fraunces, Georgia, serif",
      "body": "Inter, -apple-system, system-ui, sans-serif",
      "mono": "JetBrains Mono, monospace"
    },
    "spacing": {
      "3xs": "0.125rem", "2xs": "0.25rem", "xs": "0.5rem",
      "sm": "0.75rem", "md": "1rem", "lg": "1.5rem",
      "xl": "2rem", "2xl": "3rem", "3xl": "4rem", "4xl": "6rem"
    },
    "radii": {
      "sm": "0.375rem", "md": "0.625rem", "lg": "1rem",
      "xl": "1.25rem", "full": "9999px"
    },
    "fontSize": {
      "xs": "0.75rem", "sm": "0.875rem", "base": "1rem",
      "lg": "1.125rem", "xl": "1.25rem", "2xl": "1.625rem",
      "3xl": "2rem", "4xl": "2.5rem", "5xl": "3.25rem", "6xl": "4rem"
    },
    "lineHeight": {
      "tight": 1.2, "snug": 1.4, "normal": 1.65, "relaxed": 1.75, "loose": 1.9
    }
  }
}
