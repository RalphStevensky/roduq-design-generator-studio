{
  "name": "@roduq/mcp-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Roduq MCP (Model Context Protocol) stdio server exposing design output state to Claude Code in client repos. Roduq Addition under LICENSE-ROduQ.txt.",
  "license": "SEE LICENSE IN ../../LICENSE-ROduQ.txt",
  "main": "./dist/index.js",
  "bin": {
    "roduq-mcp-server": "./dist/index.js"
  },
  "files": [
    "dist",
    "src",
    "tsconfig.json",
    "README.md",
    "AGENTS.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "default": "./dist/server.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run -c vitest.config.ts",
    "test:watch": "vitest -c vitest.config.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.18.0",
    "ajv": "8.17.1",
    "ajv-formats": "3.0.1",
    "zod": "3.25.71"
  },
  "devDependencies": {
    "@types/node": "20.19.39",
    "typescript": "5.9.3",
    "vitest": "4.1.6"
  },
  "engines": {
    "node": "~24"
  }
}
