# Roduq Design Studio — environment configuration template
# Copy do `.env.local` (gitignored) i wypełnij wartościami z provider dashboards.

# === LLM provider keys (multi-provider — Roduq nie ma vendor lock-in) ===
# Anthropic — primary dla design generation (Claude Sonnet 4.6+)
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — alternative (GPT-5 / GPT-4o)
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Google Gemini — alternative (Gemini 2.5 Pro)
# https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=AIza...

# === Roduq output protocol ===
# Output directory dla artifacts consumed by @roduq/cli w roduq-web-starter.
# Default: ${HOME}/.roduq/output. Override gdy chcesz inny location.
# Windows native: C:/Users/<user>/.roduq/output (per BRIDGE.md § 3).
ROduQ_OUTPUT_DIR=

# === Upstream Open Design optional config ===
# Patrz upstream README.md / QUICKSTART.md dla pełnej listy upstream env vars.
# OD_PORT — daemon web proxy target port (set automatically by tools-dev)
# OD_WEB_PORT — web listener port (set automatically by tools-dev)
# Telemetry (POSTHOG_*) — opt-in only, w Roduq deployment outdomyślnie disabled.
